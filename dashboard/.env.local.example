# Supabase Configuration
# Get these from your Supabase project settings: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: For server-side operations (if needed)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Cerebras API Key (for AI Chat feature)
# Get your API key from: https://cerebras.ai/
CEREBRAS_API_KEY=your-cerebras-api-key-here

# Note: If Supabase credentials are not provided, the dashboard will
# automatically fall back to using CSV files from the data directory.
